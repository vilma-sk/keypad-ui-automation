{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "types": ["node", "@playwright/test"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "playwright.config.ts",
    "src/pages/**/*.ts",
    "tests/**/*.ts"
, "src/config/testConfig.ts"  ]
}